# 服务端口
PORT=6038

# 监控频率与超时
CHECK_INTERVAL_MS=60000
REQUEST_TIMEOUT_MS=10000
SSL_CHECK_TIMEOUT_MS=10000
FAILURE_THRESHOLD=10

# 本地调试：npm run dev / dev:local 会自动设置 UPTIME_DEV=1，关闭 Telegram 轮询与告警
# UPTIME_DEV=1

# Telegram 告警
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件接口
EMAIL_API_URL=http://localhost:3000/api/send-email
EMAIL_API_KEY=your-api-key
EMAIL_TO=your-mail@example.com

# 页面访问密码
PAGE_PASSWORD=123456

